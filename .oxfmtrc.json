{
  "printWidth": 100,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "endOfLine": "lf",
  "ignorePatterns": [
    "node_modules",
    "dist",
    "**/generated/**",
    ".github/workflows/**",
    "check-deps/**",
    "check-synth/**",
    "fixtures/expected/**",
    "**/package-lock.json"
  ]
}
