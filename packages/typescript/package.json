{
  "name": "@ghagen/ghagen",
  "version": "0.4.0",
  "description": "Generate GitHub Actions workflow YAML from TypeScript/JavaScript code",
  "keywords": [
    "cd",
    "ci",
    "code-generation",
    "github-actions",
    "workflow",
    "yaml"
  ],
  "license": "MIT",
  "author": "Nathan Jordan <nathan.m.jordan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nathanjordan/ghagen",
    "directory": "packages/typescript"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ghagen": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate-types": "tsx scripts/generate-types.ts",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "dependencies": {
    "commander": "^13.0.0",
    "jiti": "^2.4.0",
    "semver": "^7.6.0",
    "smol-toml": "^1.3.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/semver": "^7.5.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "execa": "^9.5.0",
    "json-schema-to-typescript": "^15.0.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
